{
  "name": "fuse-vscode",
  "displayName": "Fuse Language",
  "description": "Syntax highlighting and LSP support for the Fuse programming language",
  "version": "0.9.9",
  "publisher": "fuse",
  "license": "Apache-2.0",
  "homepage": "https://github.com/dmitrijkiltau/FUSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/dmitrijkiltau/FUSE.git",
    "directory": "tools/vscode"
  },
  "bugs": {
    "url": "https://github.com/dmitrijkiltau/FUSE/issues"
  },
  "keywords": [
    "fuse",
    "language",
    "lsp",
    "syntax-highlighting"
  ],
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "configurationDefaults": {
      "[fuse]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "title": "Fuse",
      "properties": {
        "fuse.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to fuse-lsp binary (overrides bundled/dist lookup)."
        }
      }
    },
    "languages": [
      {
        "id": "fuse",
        "aliases": [
          "Fuse",
          "fuse"
        ],
        "extensions": [
          ".fuse"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fuse",
        "scopeName": "source.fuse",
        "path": "./syntaxes/fuse.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "htmlTag",
        "description": "HTML DSL tag and component identifiers."
      },
      {
        "id": "htmlAttribute",
        "description": "Named HTML DSL attributes."
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "fuse",
        "scopes": {
          "function": [
            "entity.name.function",
            "entity.name.function.fuse"
          ],
          "type": [
            "entity.name.type",
            "entity.name.type.fuse",
            "support.type.builtin",
            "support.type.generic",
            "support.type.user",
            "support.type.builtin.fuse",
            "support.type.generic.fuse",
            "support.type.user.fuse"
          ],
          "parameter": [
            "variable.parameter",
            "variable.parameter.fuse"
          ],
          "variable": [
            "variable.other.readwrite",
            "variable.other.local",
            "variable.other.local.fuse"
          ],
          "property": [
            "variable.other.property",
            "variable.other.property.fuse"
          ],
          "htmlTag": [
            "entity.name.tag.html",
            "entity.name.class.fuse"
          ],
          "htmlAttribute": [
            "entity.other.attribute-name.html",
            "entity.other.attribute-name"
          ]
        }
      }
    ]
  }
}
